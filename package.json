{
  "name": "sde-intern-task",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"pnpm --filter sde-intern-task-api dev\" \"pnpm --filter sde-intern-task-web dev\"",
    "build": "pnpm --filter sde-intern-task-web build",
    "typecheck": "pnpm -r typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "concurrently": "^9.2.1"
  }
}
